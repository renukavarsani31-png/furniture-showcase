# Database
# For Vercel Postgres, use POSTGRES_URL (auto-generated)
# For local PostgreSQL, use DATABASE_URL
POSTGRES_URL="postgresql://user:password@localhost:5432/furniture_showcase"
DATABASE_URL="postgresql://user:password@localhost:5432/furniture_showcase"

# Server
PORT=5000
NODE_ENV=development

# Cloudinary Configuration (free image storage - cloudinary.com)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# JWT Secret for authentication
JWT_SECRET=your_very_secret_jwt_key_change_this_in_production

# Admin credentials (change these!)
ADMIN_EMAIL=admin@hirasales.com
ADMIN_PASSWORD=ChangeMeNow123!
